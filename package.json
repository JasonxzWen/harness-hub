{
  "name": "@jasonwen/harness-hub",
  "version": "0.1.11",
  "description": "Personal repo harness toolkit with lock-backed lifecycle commands.",
  "type": "module",
  "main": "dist/harnessHub.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JasonxzWen/harness-hub.git"
  },
  "homepage": "https://github.com/JasonxzWen/harness-hub#readme",
  "bugs": {
    "url": "https://github.com/JasonxzWen/harness-hub/issues"
  },
  "bin": {
    "harness-hub": "bin/harness-hub.mjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "AGENTS.md",
    "CHANGELOG.md",
    "README.md",
    "bin/",
    "capabilities/",
    "config/",
    "harness/",
    "dist/",
    "docs/",
    "openspec/config.yaml",
    "openspec/specs/",
    ".claude-plugin/",
    "skills/",
    "scripts/sync-codex-skills.mjs",
    "scripts/run-validate-skills.mjs",
    "scripts/smoke-managed-update.ps1",
    "scripts/skill-quality-inventory.ts",
    "scripts/validate-artifact-policy.ts",
    "scripts/validate-skills.ps1"
  ],
  "scripts": {
    "build": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\" && bun build ./src/harnessHub.ts --target=node --outdir=dist",
    "prepack": "bun run build",
    "test": "bun test ./tests",
    "skill:quality-inventory": "bun ./scripts/skill-quality-inventory.ts",
    "bootstrap:codex-skills": "node ./scripts/sync-codex-skills.mjs",
    "bootstrap:codex-skills:dry-run": "node ./scripts/sync-codex-skills.mjs --dry-run",
    "smoke:managed-update": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-managed-update.ps1",
    "typecheck": "tsc --noEmit",
    "validate:artifact-policy": "bun ./scripts/validate-artifact-policy.ts",
    "validate:skills": "node ./scripts/run-validate-skills.mjs -SkipExternal",
    "validate": "bun run typecheck && bun test ./tests && bun run validate:artifact-policy && bun run validate:skills",
    "validate:release": "bun run validate && bun run build && node bin/harness-hub.mjs --help && npm pack --dry-run"
  },
  "keywords": [
    "agent-harness",
    "agent-skills",
    "claude-plugin",
    "harness-hub",
    "ai-agents",
    "skills"
  ],
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
