{
  "name": "harness-hub-repository",
  "private": true,
  "description": "Repository-first deterministic migration and atomic agent skill source.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JasonxzWen/harness-hub.git"
  },
  "homepage": "https://github.com/JasonxzWen/harness-hub#readme",
  "bugs": {
    "url": "https://github.com/JasonxzWen/harness-hub/issues"
  },
  "bin": {
    "harness-hub": "bin/harness-hub.mjs"
  },
  "scripts": {
    "test": "bun test ./tests",
    "skill:quality-inventory": "bun ./scripts/skill-quality-inventory.ts",
    "sync:agent-skills": "node ./scripts/sync-agent-skills.mjs",
    "sync:agent-skills:dry-run": "node ./scripts/sync-agent-skills.mjs --dry-run",
    "typecheck": "tsc --noEmit",
    "validate:skills": "node ./scripts/run-validate-skills.mjs -SkipExternal",
    "validate": "bun run typecheck && bun test ./tests && bun run validate:skills"
  },
  "keywords": [
    "agent-harness",
    "agent-skills",
    "harness-hub",
    "ai-agents",
    "skills"
  ],
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
